# ─────────────────────────────────────────────────────────────
#  Copie este arquivo para .env.production e preencha os valores
#  NUNCA suba .env.production para o git!
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=conduta
POSTGRES_USER=conduta
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI

# ── Neo4j ─────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI

# ── Backend ───────────────────────────────────────────────────
JWT_SECRET=TROQUE_POR_SEGREDO_ALEATORIO_LONGO_AQUI
JWT_EXPIRES_IN=8h
# ADMIN_SECRET não é mais usado — acesso admin via JWT role=admin
APP_URL=https://SEU_DOMINIO.com
CORS_ORIGIN=https://SEU_DOMINIO.com

# ── OpenRouter ────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# ── Frontend (URL pública do seu domínio) ─────────────────────
VITE_API_URL=https://SEU_DOMINIO.com
# VITE_ADMIN_SECRET foi removido — não usar variáveis sensíveis no frontend
